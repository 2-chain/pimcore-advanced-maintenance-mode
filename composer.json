{
    "name": "2chain/pimcore-advanced-maintenance-mode",
    "description": "Pimcore bundle extending the built-in maintenance mode with rule-based exemptions (HTTP routes, CLI commands, IPs) and Tier-1 ergonomics (Retry-After header, activation reason, admin-session bypass, debug command).",
    "type": "pimcore-bundle",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/2-chain/pimcore-advanced-maintenance-mode",
    "support": {
        "issues": "https://github.com/2-chain/pimcore-advanced-maintenance-mode/issues",
        "source": "https://github.com/2-chain/pimcore-advanced-maintenance-mode"
    },
    "require": {
        "php": "^8.3",
        "pimcore/pimcore": "^11.0 || ^12.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^12.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "friendsofphp/php-cs-fixer": "^3.50",
        "symfony/browser-kit": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": { "TwoChain\\PimcoreAdvancedMaintenanceModeBundle\\": "" }
    },
    "autoload-dev": {
        "psr-4": { "TwoChain\\PimcoreAdvancedMaintenanceModeBundle\\Tests\\": "tests/" }
    },
    "extra": {
        "pimcore": {
            "bundles": ["TwoChain\\PimcoreAdvancedMaintenanceModeBundle\\PimcoreAdvancedMaintenanceModeBundle"]
        }
    }
}
