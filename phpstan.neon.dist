parameters:
    level: 9
    paths:
        - Attribute
        - Command
        - DependencyInjection
        - EventListener
        - HealthCheck
        - Maintenance
        - Rule
        - Service
        - Twig
        - PimcoreAdvancedMaintenanceModeBundle.php
    ignoreErrors:
        # phpstan-symfony's Configuration analyser is too tight about the
        # generic resolution of NodeBuilder<ArrayNodeDefinition>'s child-node
        # methods (booleanNode, scalarNode, integerNode, arrayNode, etc.).
        # The calls work fine at runtime — they're the documented Symfony API.
        -
            message: '#Call to method (booleanNode|scalarNode|integerNode|arrayNode)\(\) on an unknown class Symfony\\Component\\Config\\Definition\\Builder\\NodeBuilder#'
            path: DependencyInjection/Configuration.php
        # PHPStan cannot infer the shape returned by Processor::processConfiguration()
        # from the Symfony Config tree builder — all offset accesses are safe at runtime.
        -
            message: '#Offset .+ does not exist on array\{bypass_authenticated_admins:#'
            path: DependencyInjection/TwoChainAdvancedMaintenanceModeExtension.php
        # cacheCleanup is an optional duck-typed service (mixed) — calling run() is safe
        # because the caller is always a PostMaintenanceCacheCleanup-shaped object or null.
        -
            message: '#Cannot call method run\(\) on mixed\.#'
            path: Command/DisableCommand.php
        -
            message: '#Cannot call method run\(\) on mixed\.#'
            path: Maintenance/PostMaintenanceCheckTask.php
        # getSiteForRequest() existed in Pimcore 11 but was removed in Pimcore 12.
        # The runtime method_exists() guard is correct; PHPStan only analyzes one version.
        -
            message: '#Call to function method_exists\(\) with .+getSiteForRequest. will always evaluate to false\.#'
            path: EventListener/HttpExemptionListener.php

includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
